# .gitignore - Job Portal

# Environment variables
.env
.env.local
.env.*.local

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build outputs
dist/
build/
out/

# Dependencies lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Backend specific
backend/.env
backend/node_modules/
backend/dist/

# Frontend specific
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Database backups and temps
*.sql.bak
*.backup
pg_dump

# Logs
logs/
*.log

# Temporary files
*.tmp
.temp

# OS files
Thumbs.db
.DS_Store
